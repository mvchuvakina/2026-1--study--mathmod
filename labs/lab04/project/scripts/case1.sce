// ===================================================
// Случай 1: Гармонический осциллятор без затухания
// Уравнение: x'' + 10.5x = 0
// Начальные условия: x0 = -0.7, v0 = 0.8
// Интервал: t ∈ [0; 54], шаг 0.05
// ===================================================

funcprot(0);  // Отключаем предупреждения о переопределении функций
clear; clf; clc;

// Создаём директорию для результатов, если её нет
mkdir("../results");
mkdir("../plots");

// Параметры
omega_sq = 10.5;    // ω₀²
gamma = 0;          // коэффициент затухания
t0 = 0;             // начальное время
x0 = -0.7;          // начальное смещение
v0 = 0.8;           // начальная скорость
t = 0:0.05:54;      // массив времени с шагом 0.05

// Внешняя сила (отсутствует)
function f_val = f(t)
    f_val = 0;
endfunction

// Система дифференциальных уравнений первого порядка
function dx = ode_system(t, x_vec)
    dx(1) = x_vec(2);                                    // dx/dt = v
    dx(2) = -omega_sq * x_vec(1) - gamma * x_vec(2) - f(t); // dv/dt = -ω₀²·x - γ·v - f(t)
endfunction

// Решение системы ОДУ
sol = ode([x0; v0], t0, t, ode_system);

// Извлечение результатов
x = sol(1, :);   // смещение
v = sol(2, :);   // скорость

// Сохранение данных (исправлено: создаём файл вручную)
csv_data = [t' x' v'];
write_csv(csv_data, "../results/case1_data.csv");

// ==================== Построение графиков ====================

// График 1: Временной ряд
scf(1);
subplot(2,1,1);
plot(t, x, 'b-', 'LineWidth', 1.5);
xlabel('Время t, с');
ylabel('Смещение x');
title('Случай 1: Осциллятор без затухания (x'' + 10.5x = 0)');
xgrid();
legend('x(t)');

// График 2: Фазовый портрет
subplot(2,1,2);
plot(x, v, 'r-', 'LineWidth', 1.5);
xlabel('Смещение x');
ylabel('Скорость v = x''');
title('Фазовый портрет (без затухания)');
xgrid();
legend('Фазовая траектория');

// Сохранение графика
xs2png(gcf(), "../plots/case1_plots.png");

// Вывод информации
disp("===================================================");
disp("Случай 1: Осциллятор без затухания");
disp("===================================================");
disp("Параметры:");
disp("  ω₀² = " + string(omega_sq));
disp("  Период T = " + string(2 * %pi / sqrt(omega_sq)) + " с");
disp("  Начальные условия: x0 = " + string(x0) + ", v0 = " + string(v0));
disp("  Количество точек: " + string(length(t)));
disp("  Максимальное смещение: " + string(max(abs(x))));
disp("  Минимальное смещение: " + string(min(x)));
disp("===================================================");
disp("График сохранён: ../plots/case1_plots.png");
disp("Данные сохранены: ../results/case1_data.csv");
